{
  "name": "apps-portal",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "concurrently -n portal,elections,simulator,pomodoro,palette,markdown -c blue,magenta,red,yellow,cyan,green \"ng serve portal\" \"ng serve elections\" \"ng serve simulator\" \"ng serve pomodoro\" \"ng serve palette\" \"ng serve markdown\"",
    "start": "ng serve portal",
    "start:pomodoro": "ng serve pomodoro",
    "start:palette": "ng serve palette",
    "start:markdown": "ng serve markdown",
    "start:elections": "ng serve elections",
    "start:simulator": "ng serve simulator",
    "build": "ng build portal && ng build pomodoro && ng build palette && ng build markdown && ng build elections && ng build simulator",
    "build:portal": "ng build portal",
    "build:pomodoro": "ng build pomodoro",
    "build:palette": "ng build palette",
    "build:markdown": "ng build markdown",
    "build:elections": "ng build elections",
    "build:simulator": "ng build simulator",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.10.1",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.1.4",
    "express": "^5.1.0",
    "hyparquet": "^1.25.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "concurrently": "^9.2.1",
    "jsdom": "^27.1.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
